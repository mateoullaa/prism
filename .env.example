# Copy to .env and fill in values. NEVER commit .env (it is in .gitignore).
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
OTX_TIMEOUT=15.0  # segundos (Rodri: 15s cubre payloads grandes)
# Ollama: in dev, point to the server via VPN (http://<ollama-server-ip>:11434); on the server, use localhost
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_TIMEOUT: 30s covers ~9s cold start (CPU-only, model not yet loaded) + inference time.
OLLAMA_TIMEOUT=30
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
LOG_PATH=./metrics/triage_log.csv

# --- v2.2 RAG runtime learning (ChromaDB + Ollama embeddings) ---
# Master switch. false → retriever degrades to no-op, pipeline behaves exactly as v2.1.
RAG_ENABLED=false
# Shadow mode: auto-classification is COMPUTED and LOGGED (would_be=...) but NEVER short-circuits.
# Keep true until leave-one-out validation confirms ~100% auto-FP precision in production.
RAG_SHADOW_MODE=true
# ChromaDB PersistentClient store (embedded in-process; bind-mounted like ./metrics).
CHROMA_PATH=./chroma_db
# Ollama embedding model (pull on the host: `ollama pull nomic-embed-text`).
EMBED_MODEL=nomic-embed-text
# Nearest neighbours fetched per query (context aggregate + auto-FP support count).
RAG_TOP_K=5
# Cosine similarity required to count a neighbour as a precedent for auto-classification.
AUTO_FP_THRESHOLD=0.92
# Minimum unanimous HIGH-confidence FP precedents above threshold required to auto-classify.
RAG_MIN_PRECEDENTS=5
